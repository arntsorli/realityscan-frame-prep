{
  "name": "realityscan-frame-prep",
  "version": "0.1.0",
  "description": "Prepare phone videos and still images for RealityScan photogrammetry imports.",
  "author": "arntsorli",
  "license": "MIT",
  "private": false,
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.electron.json && electron-builder --win portable --publish never",
    "build:dir": "npm run typecheck && vite build && tsc -p tsconfig.electron.json && electron-builder --win dir --publish never",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "ci": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "electron-log": "^5.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.32.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.1",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "no.arntsorli.realityscan-frame-prep",
    "productName": "RealityScan Frame Prep",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/app-icon.ico",
        "to": "app-icon.ico"
      }
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/sharp/**/*"
    ],
    "win": {
      "icon": "build/app-icon.ico",
      "target": [
        "portable"
      ]
    }
  }
}
